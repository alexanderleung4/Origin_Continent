  lines:
  - speakerName: Lilith
    content: "\u201C\u5514\u2026\u2026\u8BE5\u6B7B\u2026\u2026\u8FD9\u79CD\u6C61\u79FD\u7684\u529B\u91CF\u2026\u2026\u662F\u9ED1\u6B7B\u5492\u5728\u53CD\u566C\u5417\uFF1F\u201D"
