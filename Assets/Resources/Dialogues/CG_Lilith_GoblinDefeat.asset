    vfxType: 0
  - speakerName: "\u7CFB\u7EDF"
    content: "\u4F34\u968F\u5267\u70C8\u7684\u9707\u52A8\uFF0C\u8389\u8389\u4E1D\u7684\u91CD\u7532\u54E5\u5E03\u6797\u4EEC\u5F7B\u5E95\u7C89\u788E\uFF09"
