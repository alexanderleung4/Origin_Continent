    eventCommand: 
    vfxType: 0
  - speakerName: Goblin
    content: "\u201C\u5723\u6559\u519B\u7684\u56E2\u957F\u4E5F\u4E0D\u8FC7\u5982\u6B64\u3002\u6840\u6840\u6840\u3002\u201D"
