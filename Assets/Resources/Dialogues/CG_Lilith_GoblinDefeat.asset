    eventCommand: 
    vfxType: 0
  - speakerName: Lilith
    content: "\u201C\u5C31\u7B97\u8EAB\u4F53\u7834\u788E\u2026\u2026\u6211\u4E5F\u7EDD\u4E0D\u4F1A\u2026\u2026\u5411\u4F60\u4EEC\u8FD9\u79CD\u2026\u2026\u5443\u554A\uFF01\u201D"
